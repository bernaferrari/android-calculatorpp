<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Interactive Calculator Widget (4x4)
  ~ 
  ~ Full-featured calculator interface for the home screen.
  ~ Supports Material You dynamic colors and customizable opacity.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:configure="org.solovyev.android.calculator.widgets.WidgetConfigurationActivity"
    android:initialKeyguardLayout="@layout/glance_default_loading_layout"
    android:initialLayout="@layout/glance_default_loading_layout"
    android:minWidth="250dp"
    android:minHeight="250dp"
    android:minResizeWidth="180dp"
    android:minResizeHeight="180dp"
    android:previewImage="@drawable/widget_preview_calculator"
    android:resizeMode="horizontal|vertical"
    android:targetCellWidth="4"
    android:targetCellHeight="4"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen|keyguard"
    android:widgetFeatures="reconfigurable|configuration_optional"
    tools:ignore="UnusedAttribute" />
